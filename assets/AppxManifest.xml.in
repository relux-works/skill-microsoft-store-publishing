<!-- TEMPLATE. Replace Identity Name / Publisher / PublisherDisplayName
     with YOUR Store-assigned values (Product management -> Product Identity).
     @VERSION@ is filled by CI as Major.Minor.Build.0 (revision MUST be 0). -->
<?xml version="1.0" encoding="utf-8"?>
<!-- MSIX manifest template (goal v2.1 F6). @VERSION@ is filled by the CI job.
     TrustLevel="appContainer" — no runFullTrust, the "access to nothing"
     posture from the Windows research. The Microsoft Store OVERWRITES the
     Identity Name/Publisher and PublisherDisplayName on submission with the
     values reserved in Partner Center, so the placeholders below are only for
     local/sideload packaging. Capabilities: outbound to the coordinator
     (internetClient), LAN inbound for the daemon's Spotify Connect zeroconf
     (internetClientServer + privateNetworkClientServer). -->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  IgnorableNamespaces="uap uap10">

  <!-- Identity assigned by the Microsoft Store (Product ID 9P26FDCWV1GC).
       Name/Publisher MUST match exactly or the Store rejects the upload. -->
  <Identity
    Name="ReluxWorksLLC.PulsarBarycenter"
    Publisher="CN=60105954-A0D9-4E89-B32D-18AF2F423ABE"
    Version="@VERSION@"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Pulsar Barycenter</DisplayName>
    <PublisherDisplayName>Relux Works, LLC</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <Description>Общий музыкальный эфир для нескольких домов.</Description>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="ru-RU" />
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application Id="Pulsar"
      Executable="pulsar-win-amd64.exe"
      uap10:TrustLevel="appContainer"
      uap10:RuntimeBehavior="packagedClassicApp">
      <uap:VisualElements
        DisplayName="Pulsar"
        Description="Общий музыкальный эфир для нескольких домов."
        BackgroundColor="#12103a"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
          Square71x71Logo="Assets\Square71x71Logo.png"
          Square310x310Logo="Assets\Square310x310Logo.png"
          Wide310x150Logo="Assets\Wide310x150Logo.png" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <Capability Name="internetClient" />
    <Capability Name="internetClientServer" />
    <Capability Name="privateNetworkClientServer" />
  </Capabilities>
</Package>
